# Supabase — find these in your project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
# Optional — defaults to claude-haiku-4-5-20251001
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Stripe — find these in your Stripe Dashboard > Developers > API keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# The price ID for your Pro plan subscription product
NEXT_PUBLIC_STRIPE_PRICE_ID=price_...

# App URL (used for Stripe redirect URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000
